APP_ENV=local
APP_PORT=8001

# PostgreSQL — schema-per-tenant multi-tenant setup
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=convision
DB_USERNAME=convision
DB_PASSWORD=secret
DB_SSLMODE=disable          # use "require" or "verify-full" on AWS RDS

JWT_SECRET=change_this_jwt_secret_before_production
JWT_TTL_HOURS=24

LOG_LEVEL=debug

STORAGE_DRIVER=local
STORAGE_LOCAL_PATH=./uploads
STORAGE_LOCAL_BASE_URL=http://localhost:8001
# STORAGE_DRIVER=s3
# STORAGE_S3_BUCKET=convision-uploads
# STORAGE_S3_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
