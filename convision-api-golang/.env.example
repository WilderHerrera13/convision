APP_ENV=local
APP_PORT=8001
# Tenant slug for local dev routing. Use 'main' for regular tenant testing,
# 'admin' for super admin testing (routes to platform schema).
DEFAULT_TENANT_SLUG=main

# PostgreSQL — schema-per-tenant multi-tenant setup
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=convision
DB_USERNAME=convision
DB_PASSWORD=secret
DB_SSLMODE=disable          # use "require" or "verify-full" on AWS RDS

JWT_SECRET=change_this_jwt_secret_before_production
JWT_TTL_HOURS=24

LOG_LEVEL=debug
